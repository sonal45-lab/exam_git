# PART 1: LOCAL vs REMOTE REPOSITORY

# Check configured remote repository
git remote -v
#  Shows fetch & push URL of remote (GitHub)

# Add remote repository (first time)
git remote add origin https://github.com/username/repo.git
#  Connect local repo to GitHub repo

# Verify remote added
git remote -v

# Clone repository into new folder
cd D:/
git clone https://github.com/username/repo.git my_copy
#  Creates new folder + copies project

cd my_copy

# Fetch updates from remote (only download, no merge)
git fetch origin
#  Safe check of remote changes

# Pull changes (download + merge into local)
git pull origin main
#  Updates local repo with latest GitHub code

# Make changes in file
notepad app.txt

# Stage file
git add app.txt

# Commit changes
git commit -m "update file"

# Push changes to GitHub
git push origin main
#  Upload local changes to remote repo


# =========================================
# PART 2: UNDO / ROLLBACK (RESET & REVERT)
# =========================================

# View commit history (short form)
git log --oneline
#  Shows commit IDs (important for rollback)

# -----------------------------------------
# RESET COMMANDS (LOCAL UNDO)
# -----------------------------------------

# Soft reset (delete commit, keep changes staged)
git reset --soft HEAD~1
#  Commit remove, changes SAFE (staging me)

# Mixed reset (default - unstage file)
git reset --mixed HEAD~1
#  Commit remove, file unstage

# Hard reset (danger - delete everything)
git reset --hard HEAD~1
#  Commit + changes permanently delete ❌


# -----------------------------------------
# DISCARD CHANGES
# -----------------------------------------

# Remove changes from working directory
git restore app.txt
#  File original state me aa jayegi


# -----------------------------------------
# SAFE UNDO (REVERT)
# -----------------------------------------

# Revert last commit safely
git revert HEAD
#  New commit create hota hai jo change reverse karta hai


# -----------------------------------------
# VERIFY CHANGES
# -----------------------------------------

# Check commit history again
git log --oneline
#  Confirm rollback or revert


# -----------------------------------------
# RECOVER DELETED COMMITS (REFLOG)
# -----------------------------------------

# Show all previous HEAD states
git reflog
#  Lost commits bhi yaha milte hain

# Restore deleted commit using ID
git reset --hard <commit_id>
#  Old commit wapas aa jayega

